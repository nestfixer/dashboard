# Railway Postgres connection string (from Railway dashboard → your Postgres plugin → Connect)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# Your Railway app URL (set after first deploy)
NEXTAUTH_URL=https://your-app.railway.app

# AI features
GOOGLE_AI_API_KEY=
GROQ_API_KEY=
